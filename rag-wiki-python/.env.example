# RAG-Wiki Python服务环境变量配置模板
# 复制此文件为 .env 并填入实际配置值

# ==================== 服务配置 ====================
SERVICE_NAME=rag-wiki-python
SERVICE_PORT=8000
DEBUG=false

# ==================== 数据库配置 ====================
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=your_mysql_user
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=rag_wiki

# ==================== Redis配置 ====================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
REDIS_DB=0

# ==================== MinIO配置 ====================
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=your_minio_access_key
MINIO_SECRET_KEY=your_minio_secret_key
MINIO_BUCKET=rag-wiki
MINIO_SECURE=false

# ==================== RabbitMQ配置 ====================
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=your_rabbitmq_user
RABBITMQ_PASSWORD=your_rabbitmq_password

# ==================== 向量数据库 ====================
VECTOR_DB_TYPE=milvus
MILVUS_HOST=localhost
MILVUS_PORT=19530
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=

# ==================== Elasticsearch ====================
ES_HOST=localhost
ES_PORT=9200

# ==================== LLM配置 ====================
LLM_PROVIDER=openai
LLM_API_KEY=your_llm_api_key
LLM_API_BASE=https://api.openai.com/v1
LLM_MODEL=gpt-4
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096

# ==================== Embedding配置 ====================
EMBEDDING_PROVIDER=openai
EMBEDDING_API_KEY=your_embedding_api_key
EMBEDDING_API_BASE=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-ada-002
EMBEDDING_DIMENSION=1536

# ==================== Reranker配置 ====================
RERANKER_MODEL=BAAI/bge-reranker-large

# ==================== 沙箱配置 ====================
SANDBOX_DOCKER_IMAGE=python:3.10-slim
SANDBOX_TIMEOUT=30
SANDBOX_MEMORY_LIMIT=512m
SANDBOX_CPU_QUOTA=50000
SANDBOX_POOL_SIZE=5

# ==================== 分块配置 ====================
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# ==================== 检索配置 ====================
RETRIEVAL_TOP_K=10
RERANK_TOP_K=5
HYBRID_SEARCH_ALPHA=0.7

# ==================== 安全配置 ====================
AUTH_SECRET_KEY=your_jwt_secret_key_change_in_production

# ==================== 链路追踪 ====================
OTEL_ENABLED=false
OTEL_SERVICE_NAME=rag-wiki-python
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
ENVIRONMENT=production
